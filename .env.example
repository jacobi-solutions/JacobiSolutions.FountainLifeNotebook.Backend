APP_ENV=local
AUTH_MODE=local
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_KNOWLEDGE_BASE_DATA_SOURCE_ID=
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_KNOWLEDGE_BASE_MODEL_ARN=
COGNITO_CLIENT_ID=
COGNITO_USER_POOL_ID=
DOCUMENT_STORAGE_PROVIDER=local
DOCUMENT_STORAGE_ROOT=var/uploads
FRONTEND_ORIGIN=http://localhost:5173
LLM_PROVIDER=mock
RETRIEVAL_PROVIDER=local
LOG_APPLICATION_NAME=FountainLifeNotebook.Backend
LOG_DIRECTORY=var/logs
LOG_FILE_NAME=backend-%DATE%.log
LOG_LEVEL=Information
LOCAL_AUTH_EMAIL=local.user@fountainlife.local
LOCAL_AUTH_USER_ID=local-user
LOCAL_AUTH_USERNAME=Local User
MONGODB_DATABASE=fountain-life-notebook
MONGODB_URI=mongodb://localhost:27017/fountain-life-notebook
PORT=3000
STORAGE_BUCKET_NAME=replace-with-s3-bucket-name

# Production/ECS shape:
# APP_ENV=production
# AUTH_MODE=cognito
# DOCUMENT_STORAGE_PROVIDER=s3
# LLM_PROVIDER=bedrock
# RETRIEVAL_PROVIDER=bedrock-kb
# FRONTEND_ORIGIN=https://replace-with-cloudfront-domain.cloudfront.net
# MONGODB_URI is injected from AWS Secrets Manager.
# The ECS task role invokes Bedrock directly; no LLM API key is required.
